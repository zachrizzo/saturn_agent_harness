# Copy to a private shell/launchd environment source and fill in real values.
# Do not commit real Telegram tokens.

AUTOMATIONS_ROOT="/Users/zachrizzo/programming/ai harnnes"
SATURN_BASE_URL="http://127.0.0.1:3737"

# Create with Telegram's @BotFather.
TELEGRAM_BOT_TOKEN="123456789:replace-me"
TELEGRAM_BOT_USERNAME="your_saturn_bot"

# Send a message to your bot, then temporarily run with TELEGRAM_ALLOW_ALL=1
# and check telegram/state.json or the process logs for your chat id.
TELEGRAM_ALLOWED_CHAT_IDS="123456789"

# Optional: route new chats through a saved dashboard agent.
# SATURN_AGENT_ID="research-deep-dive"

# Optional ad-hoc defaults when SATURN_AGENT_ID is unset.
SATURN_ADHOC_CLI="claude-bedrock"
SATURN_ADHOC_MODEL="claude-sonnet-4-6"
SATURN_ADHOC_PROMPT="You are Saturn Dispatch. Help the user from Telegram."
SATURN_ADHOC_TIMEOUT_SECONDS="1800"
